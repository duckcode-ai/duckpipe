# DuckPipe Environment Variables
# Copy this to .env and fill in your values:
#   cp config-examples/.env.example .env

# ── Airflow ────────────────────────────────────────────
AIRFLOW_BASE_URL=https://your-airflow-instance.example.com
AIRFLOW_USERNAME=duckpipe
AIRFLOW_PASSWORD=

# ── Snowflake ──────────────────────────────────────────
SNOWFLAKE_ACCOUNT=myorg.us-east-1
SNOWFLAKE_USER=DUCKPIPE_SVC
SNOWFLAKE_PASSWORD=
# For key-pair auth (recommended), set the path instead:
# SNOWFLAKE_PRIVATE_KEY_PATH=~/.ssh/duckpipe_rsa_key.p8
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_ROLE=DUCKPIPE_READER

# ── dbt Cloud ─────────────────────────────────────────
DBT_API_TOKEN=
DBT_ACCOUNT_ID=
DBT_PROJECT_ID=

# ── Slack ──────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# ── Jira ───────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=duckpipe@your-org.com
JIRA_API_TOKEN=

# ── Confluence ─────────────────────────────────────────
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=duckpipe@your-org.com
CONFLUENCE_API_TOKEN=

# ── GitHub (for PR creation) ───────────────────────────
GITHUB_TOKEN=ghp_your-fine-grained-token
GITHUB_REPO=your-org/your-dbt-repo

# ── PagerDuty (optional) ──────────────────────────────
# PAGERDUTY_WEBHOOK_URL=https://events.pagerduty.com/integration/...

# ── Dashboard ─────────────────────────────────────────
# Set a token to enable remote access. If unset, dashboard binds to 127.0.0.1 only.
# DUCKPIPE_DASHBOARD_TOKEN=your-secret-dashboard-token

# ── HashiCorp Vault (optional) ───────────────────────
# VAULT_ADDR=https://vault.internal:8200
# VAULT_TOKEN=s.your-vault-token

# ── LLM — set ONE or more; DuckPipe uses the first available ──
# Priority order: Anthropic → OpenAI → Gemini
ANTHROPIC_API_KEY=sk-ant-your-key
# OPENAI_API_KEY=sk-your-openai-key
# GEMINI_API_KEY=your-gemini-api-key
